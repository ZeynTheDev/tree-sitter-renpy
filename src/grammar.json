{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "renpy",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "label_statement"
        },
        {
          "type": "SYMBOL",
          "name": "say_statement"
        },
        {
          "type": "SYMBOL",
          "name": "jump_statement"
        },
        {
          "type": "SYMBOL",
          "name": "call_statement"
        },
        {
          "type": "SYMBOL",
          "name": "scene_statement"
        },
        {
          "type": "SYMBOL",
          "name": "show_statement"
        },
        {
          "type": "SYMBOL",
          "name": "hide_statement"
        },
        {
          "type": "SYMBOL",
          "name": "python_line"
        },
        {
          "type": "SYMBOL",
          "name": "python_block"
        },
        {
          "type": "SYMBOL",
          "name": "menu_statement"
        },
        {
          "type": "SYMBOL",
          "name": "init_statement"
        },
        {
          "type": "SYMBOL",
          "name": "return_statement"
        },
        {
          "type": "SYMBOL",
          "name": "pause_statement"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "label_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "label"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": ":"
        }
      ]
    },
    "say_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "identifier"
            },
            {
              "type": "SYMBOL",
              "name": "string"
            }
          ]
        }
      ]
    },
    "jump_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "jump"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "call_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "call"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "return_statement": {
      "type": "STRING",
      "value": "return"
    },
    "pause_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "pause"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "number"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "scene_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "scene"
        },
        {
          "type": "SYMBOL",
          "name": "image_name"
        }
      ]
    },
    "show_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "show"
        },
        {
          "type": "SYMBOL",
          "name": "image_name"
        }
      ]
    },
    "hide_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "hide"
        },
        {
          "type": "SYMBOL",
          "name": "image_name"
        }
      ]
    },
    "menu_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "menu"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "indented_block"
        }
      ]
    },
    "menu_choice": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        ]
      }
    },
    "python_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "$"
        },
        {
          "type": "SYMBOL",
          "name": "python_content"
        }
      ]
    },
    "python_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "python"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "indented_block"
        }
      ]
    },
    "init_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "init"
            },
            {
              "type": "STRING",
              "value": "python"
            },
            {
              "type": "STRING",
              "value": ":"
            },
            {
              "type": "SYMBOL",
              "name": "indented_block"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "init"
            },
            {
              "type": "STRING",
              "value": ":"
            },
            {
              "type": "SYMBOL",
              "name": "indented_block"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "init"
            },
            {
              "type": "SYMBOL",
              "name": "number"
            },
            {
              "type": "STRING",
              "value": "python"
            },
            {
              "type": "STRING",
              "value": ":"
            },
            {
              "type": "SYMBOL",
              "name": "indented_block"
            }
          ]
        }
      ]
    },
    "indented_block": {
      "type": "PATTERN",
      "value": "(\\n[ \\t]+.+)+"
    },
    "python_content": {
      "type": "PATTERN",
      "value": ".+"
    },
    "image_name": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "identifier"
        }
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"]*"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "PATTERN",
              "value": "[^']*"
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+(\\.\\d+)?"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    },
    {
      "type": "PATTERN",
      "value": "\\r?\\n[ \\t]*"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}