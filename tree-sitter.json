{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "renpy",
      "camelcase": "Renpy",
      "title": "Ren'Py",
      "scope": "source.renpy",
      "file-types": [
        "rpyc",
        "rpym",
        "rpymc",
        "rpy"
      ],
      "injection-regex": "^renpy$",
      "class-name": "TreeSitterRenpy"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Ren'Py",
    "authors": [
      {
        "name": "ZeynTheDev",
        "url": "github.com/ZeynTheDev"
      }
    ],
    "links": {
      "repository": "https://github.com/ZeynTheDev/tree-sitter-renpy",
      "funding": "https://trakteer.id/zeynthedeveloper/"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}